{
  "cleanupPeriodDays": 14,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_TOOL_SEARCH": "auto:5"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Task(*)",
      "Glob(*)",
      "Grep(*)",
      "Search(*)",
      "Skill(*)",
      "ToolSearch(*)",
      "NotebookEdit(*)",
      "WebSearch",
      "WebSearch(*)",
      "SendMessage(*)",
      "TeamCreate(*)",
      "TeamDelete(*)",
      "TaskCreate(*)",
      "TaskUpdate(*)",
      "TaskGet(*)",
      "TaskList(*)",
      "TaskOutput(*)",
      "TaskStop(*)",
      "EnterPlanMode(*)",
      "AskUserQuestion(*)",
      "ListMcpResourcesTool(*)",
      "ReadMcpResourceTool(*)",
      "Agent(*)",
      "TodoWrite(*)",
      "ExitPlanMode(*)",
      "EnterWorktree(*)",
      "ExitWorktree(*)",
      "RemoteTrigger(*)",
      "CronCreate(*)",
      "CronDelete(*)",
      "CronList(*)",
      "mcp__context7__*",
      "mcp__exa__*",
      "mcp__memory__*",
      "mcp__github__*",
      "mcp__fetch__*",
      "mcp__jina-reader__*",
      "mcp__notion__*",
      "mcp__claude_ai_Notion__*",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_close",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_resize"
    ],
    "deny": [
      "WebFetch",
      "WebFetch(*)",
      "Bash(rm -rf /)*",
      "Bash(rm -rf ~)*",
      "Bash(rm -rf .)*",
      "Bash(rm -r .)*",
      "Bash(rm -r ./)*",
      "Bash(rm -rf *)*",
      "Bash(sudo:*)",
      "Bash(chmod 777:*)",
      "Bash(>/dev/*)",
      "Bash(curl*|*sh)*",
      "Bash(wget*|*sh)*",
      "Bash(*>~/.ssh/*)",
      "Bash(*>~/.zshrc)*",
      "Bash(*>~/.bashrc)*",
      "Bash(*>~/.profile)*",
      "Bash(*>~/.zprofile)*",
      "Bash(git push --force*main)*",
      "Bash(git push -f*main)*",
      "Bash(git push --force*master)*",
      "Bash(git push -f*master)*",
      "Bash(git push --force-with-lease*main)*",
      "Bash(git push --force-with-lease*master)*",
      "Bash(git push origin +main)*",
      "Bash(git push origin +master)*",
      "Bash(git reset --hard origin/*)*",
      "Bash(git clean -f*)*",
      "Bash(git checkout -- .)*",
      "Bash(git restore .)*",
      "Bash(npm publish)*",
      "Bash(pnpm publish)*",
      "Bash(yarn publish)*",
      "Bash(docker system prune)*",
      "Bash(mkfs*)*",
      "Bash(dd if=*)*",
      "Bash(eval *)*",
      "Bash(bash -c *)*",
      "Bash(/bin/bash -c *)*",
      "Bash(sh -c *)*",
      "Bash(/bin/sh -c *)*",
      "Bash(osascript*)*",
      "Bash(/usr/bin/osascript*)*",
      "Bash(crontab*)*",
      "Bash(launchctl*)*",
      "Bash(python3 -c *import os*)*",
      "Bash(python3 -c *import subprocess*)*",
      "Bash(python3 -c *import importlib*)*",
      "Bash(python3 -c *__import__*)*",
      "Bash(node -e *)*",
      "Bash(/usr/local/bin/node -e *)*",
      "Bash(perl -e *)*",
      "Bash(/usr/bin/perl -e *)*",
      "Bash(xargs *)*",
      "Bash(open http*)*",
      "Bash(source /dev/*)*"
    ],
    "additionalDirectories": [
      "/Users/gihoonkim/.claude",
      "/Users/gihoonkim/.claude/homunculus/instincts/personal",
      "/Users/gihoonkim/Projects/special-education-web/.claude/checkpoints",
      "/Users/gihoonkim/.claude/hooks",
      "/Users/gihoonkim/claude-forge/hooks",
      "/Users/gihoonkim/.claude/agents",
      "/Users/gihoonkim/claude-forge/agents",
      "/Users/gihoonkim/.claude/commands",
      "/Users/gihoonkim/claude-forge/commands",
      "/Users/gihoonkim/Projects/special-education-web/.claude",
      "/Users/gihoonkim/Projects/special-education-web/.git",
      "/Users/gihoonkim/.claude/rules",
      "/Users/gihoonkim/.claude/upskill-poc/skills"
    ]
  },
  "model": "claude-opus-4-6",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/remote-command-guard.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/build-required-check.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/pending-json-remind.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/contract-version-check.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "mcp__*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/rate-limiter.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/mcp-usage-tracker.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/genie-session-start.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/context-sync-suggest.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/forge-update-check.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/notion-todo-inject.sh",
            "timeout": 8000
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/today-task-inject.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/claude-md-guard.sh",
            "timeout": 3000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/work-tracker-prompt.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/work-tracker-tool.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/output-secret-filter.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "~/.claude/skills/continuous-learning-v2/hooks/observe.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/code-quality-reminder.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/code-quality-reminder.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/security-auto-trigger.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command // \"\"' | grep -q 'git commit' && ~/.claude/hooks/notion-pending-poster.sh || true",
            "timeout": 20000
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.command // \"\"' | grep -q 'git commit' && ~/.claude/hooks/genie-commit-sync.sh || true",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/v-auto-verify.sh",
            "timeout": 60000
          }
        ]
      },
      {
        "matcher": "mcp__notion__*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notion-usage-marker.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/genie-session-stop.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/notion-pending-poster.sh",
            "timeout": 20000
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/work-tracker-stop.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/session-wrap-suggest.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/notion-update-reminder.sh"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/post-compact-restore.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/task-completed.sh",
            "timeout": 10000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/cc-chips-custom/engine.sh"
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "effortLevel": "high"
}
